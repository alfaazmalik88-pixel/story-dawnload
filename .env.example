# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_DATABASE_URL: Your Firebase Realtime Database URL (e.g. https://your-project-default-rtdb.firebaseio.com)
FIREBASE_DATABASE_URL=your_firebase_database_url

# FIREBASE_API_KEY: Your Firebase Web API key
FIREBASE_API_KEY=your_firebase_api_key

# FIREBASE_PROJECT_ID: Your Firebase Project ID
FIREBASE_PROJECT_ID=your_firebase_project_id

# FIREBASE_APPLICATION_ID: Your Firebase Application ID (Google App ID)
FIREBASE_APPLICATION_ID=your_firebase_application_id
